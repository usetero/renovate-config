{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":ignoreUnstable",
    "mergeConfidence:all-badges"
  ],
  "platformAutomerge": true,
  "automergeType": "pr",
  "rebaseWhen": "behind-base-branch",
  "ignoreTests": false,
  "labels": ["dependencies"],
  "schedule": [
    "after 10pm every weekday",
    "before 6am every weekday",
    "every weekend"
  ],
  "minimumReleaseAge": "3 days",
  "major": {
    "dependencyDashboardApproval": true
  },
  "packageRules": [
    {
      "description": "Automerge safe update types when checks pass",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Automerge minor updates for Go dependencies",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "description": "Automerge minor updates for npm dependencies",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "description": "Automerge and group Go patch updates to reduce noise",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch"],
      "groupName": "go dependencies (patch)"
    },
    {
      "description": "Group Terraform updates",
      "matchManagers": ["terraform"],
      "groupName": "terraform"
    },
    {
      "description": "Automerge and group GitHub runners updates (no stability wait)",
      "matchDatasources": ["github-runners"],
      "matchUpdateTypes": ["patch", "pin"],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "groupName": "github runners"
    },
    {
      "description": "Automerge and group Hermit tool updates (no stability wait)",
      "matchDatasources": ["hermit"],
      "matchUpdateTypes": ["patch", "pin"],
      "minimumReleaseAge": "0 days",
      "automerge": true,
      "groupName": "hermit tools"
    },
    {
      "description": "Automerge GitHub Actions (no stability wait, except digger)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "minimumReleaseAge": "0 days",
      "automerge": true
    },
    {
      "description": "Do not automerge digger action updates",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["diggerhq/digger"],
      "automerge": false
    },
    {
      "description": "Automerge dev dependencies patch updates",
      "matchUpdateTypes": ["patch"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "description": "Docker digest updates: weekly, automerge",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "schedule": ["before 6am on monday"],
      "automerge": true,
      "groupName": "docker digests"
    },
    {
      "description": "Automerge and group Docker patch updates",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "groupName": "docker dependencies (patch)"
    },
    {
      "description": "Group Docker major updates (manual review)",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "groupName": "docker dependencies (major)"
    },
    {
      "description": "npm: longer wait period",
      "matchManagers": ["npm"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Group npm minor/patch updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchDepTypes": ["dependencies"],
      "groupName": "npm dependencies (minor/patch)"
    },
    {
      "description": "Group npm major updates (manual review)",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "groupName": "npm dependencies (major)"
    },
    {
      "description": "Group npm devDependencies minor/patch",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchDepTypes": ["devDependencies"],
      "groupName": "npm devDependencies (minor/patch)"
    },
    {
      "description": "Group Go major updates (manual review)",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": "go dependencies (major)"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Pin activate-hermit to releases only (commits get force-pushed away)",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["cashapp/activate-hermit"],
      "versioning": "semver",
      "extractVersion": "^v(?<version>.*)$"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "minimumReleaseAge": "0 days",
    "schedule": ["before 6am on monday"]
  },
  "prConcurrentLimit": 5,
  "prHourlyLimit": 4,
  "vulnerabilityAlerts": {
    "labels": ["dependencies", "security"],
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days"
  }
}
